# Mantle Sepolia
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_CHAIN_ID=5003
MANTLE_EXPLORER=https://sepolia.mantlescan.xyz

# USDC — deployed as a 6-decimal ERC20 mock by scripts/deploy.ts (leave blank until deployed)
USDC_ADDRESS=

# EURC (Mantle Sepolia testnet)
EURC_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a

# Circle Gateway (Nanopayments)
GATEWAY_WALLET_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
GATEWAY_MINTER_ADDRESS=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B

# Trade execution toggle. false = agents log intent only; true = real venue calls.
ENABLE_REAL_TRADES=false

# ---------------------------------------------------------------------------
# Hyperliquid (TESTNET by default — flip to mainnet by switching the blocks)
# Agents hold pre-funded USDC on HyperEVM and trade perps directly — no CCTP.
# ---------------------------------------------------------------------------
HYPERLIQUID_API_URL=https://api.hyperliquid-testnet.xyz
HYPERLIQUID_INFO_URL=https://api.hyperliquid-testnet.xyz/info
HYPERLIQUID_EXCHANGE_URL=https://api.hyperliquid-testnet.xyz/exchange
HYPERLIQUID_CHAIN_ID=998
DEST_RPC_URL=https://rpc.hyperliquid-testnet.xyz/evm

# --- Mainnet alternative (commented; switch + restart to use) ---
# HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
# HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info
# HYPERLIQUID_EXCHANGE_URL=https://api.hyperliquid.xyz/exchange
# HYPERLIQUID_CHAIN_ID=999
# DEST_RPC_URL=https://rpc.hyperliquid.xyz/evm

# Wallets (hex private keys — generate with scripts/create-wallets.ts)
PRIVATE_KEY_ALLOCATOR=0x...
PRIVATE_KEY_HERMES=0x...
PRIVATE_KEY_PYTHIA=0x...
PRIVATE_KEY_DEMETER=0x...

# Deployed contract addresses (filled after: pnpm tsx scripts/deploy.ts)
VAULT_ADDRESS=0x...
NEXT_PUBLIC_VAULT_ADDRESS=0x...
REGISTRY_ADDRESS=0x...
ANCHOR_ADDRESS=0x...

# Real on-chain venues on Mantle Sepolia (deployed + seeded by scripts/deploy.ts)
YIELD_VAULT_ADDRESS=0x...   # MantleYieldVault (ERC-4626) — demeter's real yield venue
PERP_ADDRESS=0x...          # MantleOraclePerp — hermes/pythia's real perp venue
PERP_LEVERAGE=2             # perp notional = collateral * leverage (1-10)

# Real Pyth oracle on Mantle Sepolia (verified live) + Hermes price service
PYTH_ADDRESS=0x98046Bd286715D3B0BC227Dd7a956b83D8978603
PYTH_HERMES_URL=https://hermes.pyth.network

# Agent wallet addresses (output of scripts/create-wallets.ts)
AGENT_ADDRESS_HERMES=0x...
AGENT_ADDRESS_PYTHIA=0x...
AGENT_ADDRESS_DEMETER=0x...

# Gas on Mantle is paid in MNT (18 dec). Fund every wallet with test MNT from the faucet.

# Circle Developer-Controlled Wallets
# Get these from https://console.circle.com → Developer Wallets
CIRCLE_API_KEY=TEST_API_KEY:...
CIRCLE_ENTITY_SECRET=<32-byte hex entity secret from Circle Console>
CIRCLE_WALLET_SET_ID=<filled after running scripts/create-wallets.ts>

# AI (agent reasoning via OpenAI)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# IPFS
PINATA_JWT=...

# Services (local)
ALLOCATOR_URL=http://localhost:3001
INDEXER_URL=http://localhost:3002
NEXT_PUBLIC_INDEXER_URL=http://localhost:3002
NEXT_PUBLIC_INDEXER_WS_URL=ws://localhost:3002

# Dashboard onboarding: faucet for testnet MNT (gas) on Mantle Sepolia.
NEXT_PUBLIC_FAUCET_URL=https://faucet.sepolia.mantle.xyz

# External APIs
TWITTER_BEARER_TOKEN=...

# ---------------------------------------------------------------------------
# Agent timing (Phase 2 — 20-min full-roundtrip cycle, 10-min hold)
# ---------------------------------------------------------------------------
AGENT_CYCLE_MS=1200000        # 20 min — total cycle length
HERMES_HOLD_MS=600000         # 10 min — HL position hold window
PYTHIA_HOLD_MS=600000         # 10 min — HL position hold window
DEMETER_HOLD_MS=900000        # 15 min — USYC deposit hold window
ATTESTATION_TIMEOUT_MS=600000 # 10 min — Iris polling timeout

# ---------------------------------------------------------------------------
# Docker / production hosting (infra/docker-compose.yml)
# ---------------------------------------------------------------------------
# Public hostname Caddy serves the indexer on (auto-TLS via Let's Encrypt).
# Point an A/AAAA DNS record at the VM before bringing up Caddy.
INDEXER_DOMAIN=indexer.pantheon.example
# Persistent SQLite paths inside the indexer / allocator containers.
# docker-compose mounts named volumes at the parent dirs.
INDEXER_DB_PATH=/data/indexer/pantheon.db
ALLOCATOR_DB_PATH=/data/allocator/state.db
