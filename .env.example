MESSAGE_TRANSMITTER_DEST=0x81D40F21F12A8F0E3252Bccb954D722d4c464B64
# Use testnet: 0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275
DEST_RPC_URL=https://rpc.hyperliquid.xyz/evm
