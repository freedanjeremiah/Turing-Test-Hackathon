GATEWAY_MINTER_ADDRESS=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B

# CCTP V2 — Mantle Sepolia testnet (source)
CCTP_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
ARC_CCTP_DOMAIN=26
ENABLE_REAL_TRADES=false

# CCTP V2 — HyperEVM (destination for Hermes/Pythia)
